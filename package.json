    "@originjs/vite-plugin-commonjs": "^1.0.3",
    "@vitejs/plugin-react": "^5.1.1",
    "adblock-detect-react": "^1.3.1",
    "colormap": "^2.3.2",
    "html-to-image": "^1.11.13",
    "mathjs": "15.2.0",
    "mui-nested-menu": "^4.0.1",
    "react": "^19.2.0",
