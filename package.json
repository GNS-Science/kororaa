    "react-dom": "^19.2.0",
    "react-ga4": "^2.1.0",
    "react-markdown": "^10.1.0",
    "react-relay": "^20.1.1",
    "react-router-dom": "^7.9.6",
    "react-to-print": "^3.2.0",
    "react-tooltip": "^5.30.0",
    "remark-gfm": "^4.0.1",
    "uuid": "^13.0.0",
    "vite": "8",
    "vite-plugin-relay": "^2.1.0",
    "web-vitals": "^3.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint -c eslint.config.mjs . --report-unused-disable-directives --max-warnings 0",
    "prettier-check": "prettier -c --ignore-path .prettierignore \"**/*.{css,html,ts,tsx,js,json,md,yaml,yml}\"",
    "prettify": "prettier --write --ignore-path .prettierignore \"**/*.{css,html,ts,tsx,js,json,md,yaml,yml}\"",
    "preview": "vite preview",
    "relay": "relay-compiler",
    "test": "vitest",
    "changelog": "auto-changelog -p -o src/CHANGELOG.md -t keepachangelog"
  },
  "lint-staged": {
    "./src/**/*.{ts,tsx}": [
      "eslint --quiet --fix"
    ]
  },
  "jest": {
    "resetMocks": false,
    "transformIgnorePatterns": [
      "node_modules/(?!d3-array|leaflet|react-leaflet-fullscreen-plugin)/"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-transform-private-property-in-object": "^7.27.1",
    "@eslint/compat": "^2.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/colormap": "^2.3.4",
    "@types/geojson": "^7946.0.16",
    "@types/jest": "^30.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/lodash": "^4.17.21",
    "@types/node": "~24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-relay": "^18.2.1",
    "@types/relay-test-utils": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitest/coverage-v8": "^4.0.14",
    "auto-changelog": "^2.5.0",
    "babel-plugin-relay": "^20.1.1",
    "cypress": "^15.7.0",
    "cypress-localstorage-commands": "^2.2.8",
    "cypress-real-events": "^1.15.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^5.2.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "get-graphql-schema": "^2.1.2",
    "husky": "^9.1.7",
    "jsdom": "^27.2.0",
    "lint-staged": "^16.2.7",
    "msw": "2.12.3",
    "prettier": "^3.7.3",
    "relay-compiler": "^20.1.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "msw": {
    "workerDirectory": "public"
  },
  "resolutions": {
    "brace-expansion": "5.0.5",
    "graphql": "16.13.2",
    "js-yaml": "4.1.1",
    "uuid": "14.0.0",
    "headers-polyfill": "3.2.5",
    "esbuild": "0.28.0",
    "flatted": "3.4.2",
